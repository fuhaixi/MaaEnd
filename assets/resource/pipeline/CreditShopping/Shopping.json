{
    "CreditShoppingShopping": {
        "desc": "信用购物",
        "recognition": "TemplateMatch",
        "roi": [
            813,
            44,
            293,
            82
        ],
        "template": "CreditShopping/CreditShoppingTabSelected.png",
        "threshold": 0.7,
        "next": [
            "CreditShoppingInit",
            "CreditShoppingScanItem"
        ]
    },
    "CreditShoppingInit": {
        "desc": "初始化信用购物参数（仅执行一次）",
        "max_hit": 1,
        "recognition": "DirectHit",
        "action": "Custom",
        "custom_action": "CreditShoppingParseParams",
        "next": [
            "CreditShoppingScanItem"
        ]
    },
    "CreditShoppingScanItem": {
        "recognition": "TemplateMatch",
        "roi": [
            813,
            44,
            293,
            82
        ],
        "template": "CreditShopping/CreditShoppingTabSelected.png",
        "threshold": 0.7,
        "next": [
            "AutoGetCredits",
            "CreditShoppingBuyFirst",
            "CreditShoppingReserveCredit",
            "CreditShoppingBuyNormalWithDiscount",
            "CreditShoppingBuyBlacklist",
            "CreditShippingCanNotToBuy",
            "ADBSpecial",
            "RefreshItem",
            "CreditShoppingNothingToBuy"
        ]
    },
    "ADBSpecial": {
        "desc": "ADB特殊流程,向上滑动一段",
        "enabled": false,
        "action": {
            "type": "Swipe",
            "param": {
                "begin": [
                    640,
                    500
                ],
                "end": [
                    640,
                    300
                ],
                "duration": 500
            }
        },
        "next": [
            "AutoGetCredits",
            "CreditShoppingBuyFirst",
            "CreditShoppingBuyNormalWithDiscount",
            "CreditShoppingBuyBlacklist",
            "CreditShippingCanNotToBuy",
            "CreditShoppingReserveCredit",
            "CreditShoppingPrudentRefresh",
            "RefreshItem",
            "CreditShoppingNothingToBuy"
        ]
    },
    "CreditShippingCanNotToBuy": {
        "desc": "刷新流程中无法购买",
        "enabled": false,
        "recognition": "Or",
        "any_of": [
            "AutoGetCredits",
            "CanNotFlash"
        ],
        "next": [
            "CreditShoppingNothingToBuy"
        ],
        "focus": {
            "Node.Action.Succeeded": "$task.CreditShopping.refresh_no_credit"
        }
    },
    "RefreshItem": {
        "desc": "刷新商品",
        "enabled": false,
        "recognition": "And",
        "all_of": [
            "RefreshText"
        ],
        "action": "Click",
        "post_wait_freezes": {
            "time": 500,
            "timeout": 2000,
            "target": [
                66,
                97,
                1153,
                544
            ]
        },
        "next": [
            "CreditShoppingShopping",
            "[JumpBack]YellowConfirmButtonType1"
        ],
        "focus": {
            "Node.Action.Succeeded": "刷新商品"
        }
    },
    "CreditShoppingReserveCredit": {
        "desc": "信用点低于保留阈值",
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "ExpressionRecognition",
                "custom_recognition_param": {
                    "expression": "{CreditShoppingReserveCreditOCRInternal}<300"
                }
            }
        },
        "next": [
            "CreditShoppingNothingToBuy"
        ],
        "focus": {
            "Node.Recognition.Succeeded": "$task.CreditShopping.reserve_credit_reached"
        }
    },
    "CreditShoppingReserveCreditOCRInternal": {
        "desc": "识别当前信用点",
        "recognition": "OCR",
        "roi": [
            1083,
            0,
            135,
            71
        ],
        "expected": "^\\d+$",
        "color_filter": "CreditShoppingReserveCreditOCRInternalColor"
    },
    "CreditShoppingReserveCreditOCRInternalColor": {
        "recognition": {
            "type": "ColorMatch",
            "param": {
                "roi": [
                    1083,
                    17,
                    114,
                    27
                ],
                "method": 6,
                "lower": [
                    198
                ],
                "upper": [
                    255
                ]
            }
        }
    },
    "AutoGetCredits": {
        "desc": "额度不足时候自动去基建获取",
        "max_hit": 1,
        "recognition": "Or",
        "any_of": [
            "AutoGetCreditsBuy"
        ],
        "next": [
            "[JumpBack]NeedCredit",
            "CreditShoppingShopping",
            "CreditShoppingCheckShopPage",
            "[JumpBack]SceneEnterMenuShop"
        ],
        "focus": {
            "Node.Action.Succeeded": "$task.CreditShopping.auto_get_credits"
        }
    },
    "AutoGetCreditsBuy": {
        "recognition": "And",
        "all_of": [
            "CreditIcon",
            "NotSoldOut",
            "CanNotAfford",
            "BuyFirstOCR_CanNotAfford"
        ],
        "box_index": 3
    },
    "CreditShoppingBuyFirst": {
        "desc": "优先购买",
        "recognition": "And",
        "all_of": [
            "CreditIcon",
            "NotSoldOut",
            "CanAfford",
            "BuyFirstOCR"
        ],
        "box_index": 3,
        "action": "Click",
        "target_offset": [
            25,
            -102,
            -61,
            -8
        ],
        "next": [
            "CreditShoppingBuyItem"
        ]
    },
    "CreditShoppingBuyNormalWithDiscount": {
        //"enabled": false,
        "desc": "普通购买",
        "recognition": "And",
        "all_of": [
            "CreditIcon",
            "NotSoldOut",
            "CanAfford",
            "BlacklistOCR",
            "IsDiscount"
        ],
        "box_index": 4,
        "action": "Click",
        "next": [
            "CreditShoppingBuyItem"
        ]
    },
    "CreditShoppingBuyBlacklist": {
        "desc": "忽略黑名单",
        "recognition": "And",
        "all_of": [
            "CreditIcon",
            "NotSoldOut",
            "CanAfford"
        ],
        "box_index": 2,
        "action": "Click",
        "next": [
            "CreditShoppingBuyItem"
        ]
    },
    "CreditShoppingPrudentRefresh": {
        "desc": "稳健模式刷新，当前信用点-刷新花费低于阈值时触发",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    {
                        "recognition": {
                            "type": "Custom",
                            "param": {
                                "custom_recognition": "CreditShoppingReserveRecognition",
                                "custom_recognition_param": {
                                    "expression": "{CreditShoppingReserveCreditOCRInternal}-{RefreshCost}<400"
                                }
                            }
                        }
                    },
                    {
                        "recognition": {
                            "type": "And",
                            "param": {
                                "all_of": [
                                    "CreditIcon",
                                    "NotSoldOut",
                                    "CanAfford"
                                ]
                            }
                        }
                    }
                ],
                "box_index": 1
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "CreditShoppingBuyItem"
        ],
        "focus": {
            "Node.Recognition.Succeeded": "$task.CreditShopping.prudent_refresh_triggered"
        }
    },
    "CreditShoppingNothingToBuy": {
        "desc": "没有合适的东西可以买了",
        "recognition": "DirectHit",
        "next": [
            "InMainWindow",
            "[JumpBack]CloseButtonType1"
        ]
    }
}
